# =========================
# Build / temp
# =========================
*.log
*.tmp
*.cache
*.bak

# =========================
# Python
# =========================
**/__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/

# =========================
# Arduino build
# =========================
*.elf
*.hex
*.bin
*.map

# =========================
# OS junk
# =========================
.DS_Store
Thumbs.db

# =========================
# Data (важно — не грузим логи)
# =========================
data/*
!data/.gitkeep

# =========================
# Reference (тяжёлые PDF не нужны модели)
# =========================
reference/*.pdf

# =========================
# Scripts temp
# =========================
scripts/tmp/
scripts/output/

# =========================
# IDE
# =========================
.vscode/
.idea/

# =========================
# Git
# =========================
.git/
.gitignore

# =========================
# Claude worktrees (internal)
# =========================
.claude/worktrees/

# =========================
# Large files
# =========================
*.zip
*.tar
*.gz

# =========================
# Optional: firmware binaries if появятся
# =========================
firmware/**/build/